DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-db-password

# Optional alternative to the DB_* values above:
# DATABASE_URL=postgres://postgres:your-db-password@127.0.0.1:5432/postgres

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
MAIL_FROM="InSight <your-email@gmail.com>"

OPEN_BEAUTY_FACTS_BASE_URL=https://world.openbeautyfacts.org
OPEN_BEAUTY_FACTS_TIMEOUT_MS=5000
OPEN_BEAUTY_FACTS_USER_AGENT="InSight/1.0 (your-email@example.com)"
